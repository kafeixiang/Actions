name: Build Exclave App (Fixed)

on:
  workflow_dispatch:
    inputs:
      branch_name:
        description: '想要编译的分支名称 (例如: dev, main)'
        required: true
        default: 'dev'

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # 1. 基础环境配置：Java 21
      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'
          cache: 'gradle' # 开启 gradle 缓存，加速后续编译

      # 2. 基础环境配置：Go 1.26
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.26.x'

      # 3. 基础环境配置：Android SDK 37 与 NDK r29
      - name: Set up Android SDK & NDK
        uses: android-actions/setup-android@v3
        with:
          api-level: 37
          build-tools: 37.0.0
          ndk-version: r29

      # 4. 跨仓拉取目标代码（【重要修正】加入 submodules 递归拉取）
      - name: Checkout Target Repo
        uses: actions/checkout@v4
        with:
          repository: 'kafeixiang/Exclave'
          token: ${{ secrets.MY_GITHUB_TOKEN }}
          ref: ${{ github.event.inputs.branch_name }}
          submodules: 'recursive' # 必须递归拉取依赖的子模块源码
          path: 'Exclave-Project'

      # 5. 【新增核心步骤】安装并初始化 Go Mobile 工具
      - name: Install and Init Go Mobile
        run: |
          go install golang.org/x/mobile/cmd/gomobile@latest
          go install golang.org/x/mobile/cmd/gobind@latest
          # 将 Go 的 bin 目录临时加入系统环境变量，保证命令行能找到 gomobile
          echo "$HOME/go/bin" >> $GITHUB_PATH
          # 显式指出当前的 Android NDK 路径进行初始化
          $HOME/go/bin/gomobile init -ndk $ANDROID_NDK_ROOT

      # 6. 执行全套编译流程
      - name: Build Project
        env:
          # 显式把 Android SDK 和 NDK 路径传给底层 Go 编译脚本
          ANDROID_HOME: ${{ env.ANDROID_HOME }}
          ANDROID_NDK_HOME: ${{ env.ANDROID_NDK_ROOT }}
        run: |
          cd Exclave-Project
          
          # 赋予执行权限
          chmod +x gradlew run library/core/build.sh
          
          # 配置签名的本地属性
          echo "KEYSTORE_PASS=android" > local.properties
          echo "ALIAS_NAME=androiddebugkey" >> local.properties
          echo "ALIAS_PASS=android" >> local.properties
          
          echo "==== Step 1: 编译底层 libexclavecore ===="
          ./run lib core
          
          echo "==== Step 2: 下载及更新 Geo 资源资产 ===="
          ./gradlew :app:downloadAssets
          ./gradlew :app:updateAssets
          
          echo "==== Step 3: 最终打包 Android APK ==="
          ./gradlew :app:assembleOssRelease

      # 7. 收集并上传编译产物
      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Exclave-APK-${{ github.event.inputs.branch_name }}
          path: Exclave-Project/app/build/outputs/apk/oss/release/*.apk
